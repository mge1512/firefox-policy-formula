# firefox-policy-formula - example pillar
# SPDX-License-Identifier: Apache-2.0
# This mirrors what the SUSE Multi-Linux Manager form produces under "firefox:".

firefox:
  policies_file: /etc/firefox/policies/policies.json
  manage_policies_dir: true

  # Also drop an identical policies.json next to the binary (SLES/openSUSE path).
  manage_distribution_fallback: true
  distribution_policy_file: /usr/lib64/firefox/distribution/policies.json

  suppress_first_run_page: true
  suppress_post_update_page: true

  policies:
    DisableTelemetry: true
    DisableFirefoxStudies: true
    DisableAppUpdate: true
    DisablePocket: false
    DisableFeedbackCommands: false
    DontCheckDefaultBrowser: true
    NoDefaultBookmarks: false
    BlockAboutConfig: false
    Certificates:
      ImportEnterpriseRoots: true

  manage_dnsoverhttps: true
  dnsoverhttps:
    enabled: false
    locked: true
    fallback: true
    excluded_domains: "intranet.example.de, example.de"

  manage_aicontrols: true
  aicontrols:
    lock_settings: true
    default_state: blocked
    sidebar_chatbot: blocked
    smart_window: blocked
    translations: available

  homepage:
    url: "https://intranet.example.de"
    start_page: homepage
    locked: false

  extensions:
    - id: "uBlock0@raymondhill.net"
      installation_mode: force_installed
      install_url: "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi"

  bookmarks:
    - Title: "Intranet"
      URL: "https://intranet.example.de"
      Placement: toolbar
      Folder: "Firma"
